// Zed settings
// https://zed.dev/docs/configuring-zed
{
  // ── Agent ──────────────────────────────────────────────────────────────────
  "icon_theme": {
    "mode": "dark",
    "dark": "Colored Zed Icons Theme Dark",
    "light": "Colored Zed Icons Theme Light",
  },
  "agent": {
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-5"
    },
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  // ── Appearance ─────────────────────────────────────────────────────────────
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Iced Latte (Blur) [Heavy]",
    "dark": "Catppuccin Espresso (Blur) [Heavy]"
  },
  "ui_font_family": "JetBrains Mono Nerd Font",
  "ui_font_size": 14,
  "buffer_font_family": "JetBrains Mono Nerd Font",
  "buffer_font_size": 14,
  "buffer_font_features": {
    "calt": true,
    "liga": true
  },
  "buffer_line_height": "comfortable",
  // ── Editor ─────────────────────────────────────────────────────────────────
  "tab_size": 2,
  "hard_tabs": false,
  "soft_wrap": "none",
  "show_whitespaces": "selection",
  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "coloring": "indent_aware"
  },
  "scrollbar": {
    "show": "never"
  },
  "scroll_beyond_last_line": "one_page",
  "cursor_blink": false,
  "relative_line_numbers": "enabled",
  "gutter": {
    "line_numbers": true,
    "folds": true
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": false,
    "show_other_hints": true
  },
  // ── File handling ──────────────────────────────────────────────────────────
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "format_on_save": "on",
  "formatter": "language_server",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  // ── UI ─────────────────────────────────────────────────────────────────────
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "dock": "right",
    "default_width": 240,
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 20
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  // ── Terminal ───────────────────────────────────────────────────────────────
  "terminal": {
    "font_family": "JetBrains Mono Nerd Font",
    "font_size": 14,
    "line_height": "comfortable",
    "shell": "system",
    "dock": "bottom",
    "default_width": 640,
    "default_height": 240
  },
  // ── Git ────────────────────────────────────────────────────────────────────
  "git": {},
  // ── LSP / Languages ────────────────────────────────────────────────────────
  "languages": {},
  "lsp": {},
  // ── Vim mode ───────────────────────────────────────────────────────────────
  "vim_mode": false,
  // ── Extensions ─────────────────────────────────────────────────────────────
  "auto_install_extensions": {
    "catppuccin-blur": true,
    "colored-zed-icons-theme": true,
    "html": true,
    "lua": true,
    "toml": true,
  },
  // ── Telemetry ──────────────────────────────────────────────────────────────
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
}
