# Brewfile — Homebrew packages for development environment
# Update with: brew bundle dump --force
# Install with: brew bundle
#
# ╔════════════════════════════════════════════╗
# ║  How to update your Brewfile:             ║
# ║  Run on your current machine:             ║
# ║    bash scripts/dump-brew.sh               ║
# ║  Or manually:                              ║
# ║    brew bundle dump --force                ║
# ╚════════════════════════════════════════════╝

# ── Essential Development Tools ──────────────────────────────────────────────

# mise - Polyglot version manager (Node, Python, Ruby, etc.)
brew "mise"

# Starship - Cross-shell prompt
brew "starship"

# Mole - Mac cleanup and maintenance terminal tool
brew "mole"

# Neovim - Hyperextensible Vim-based text editor
brew "neovim"

# ── Editors ───────────────────────────────────────────────────────────────────

# Zed - High-performance, multiplayer code editor
cask "zed"

# ── Window Management ─────────────────────────────────────────────────────────

# Aerospace - i3-like tiling window manager for macOS
cask "nikitabobko/tap/aerospace"

# ── Fonts ─────────────────────────────────────────────────────────────────────
cask "font-inconsolata-nerd-font"
