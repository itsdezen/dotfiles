# =============================================================================
# .gitignore — Files not to commit to git
# =============================================================================

# ── Sensitive files ──────────────────────────────────────────────────────────
# Machine-specific overrides (e.g. ~/.zshrc.local, sourced by zsh/.zshrc)
*.local
*.secret
.env*

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Editor files ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
