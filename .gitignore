# =============================================================================
# .gitignore — Files not to commit to git
# =============================================================================

# ── Sensitive files ──────────────────────────────────────────────────────────
*.local                 # Machine-specific configs (e.g., .zshrc.local)
*.secret                # Secret files
.env*                   # Environment variables

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store               # Finder metadata
.AppleDouble
.LSOverride

# ── Backup files ─────────────────────────────────────────────────────────────
*.backup.*              # Created by link.sh when backing up existing files
*.old                   # Old files during refactoring

# ── Editor files ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Zed ──────────────────────────────────────────────────────────────────────
# Auto-generated prompt library database
zed/.config/zed/prompts/
# Auto-downloaded themes
zed/.config/zed/themes/

# ── Fonts ────────────────────────────────────────────────────────────────────
fonts/                  # Fonts installed via Homebrew, not committed
