// Copy this to ~/.config/tili/tili.kdl and edit — the daemon watches the
// file and hot-reloads on save (no restart needed). Every section below is
// optional; an omitted section just uses its built-in default. Unknown/
// misspelled sections are silently ignored rather than rejected, so it's
// safe to leave typos or future-looking config lying around — but it also
// means a section that "does nothing" after a reload is worth
// double-checking for a typo in its name.

workspaces {
    workspace "work"
    workspace "entertain"
    workspace "random"

    // Workspace names are arbitrary strings — nothing stops you from
    // declaring "1" through "9" here instead (or alongside these) for
    // numbered switching; just add your own alt-1.."9" binds below if you
    // do. Switching only ever works for a workspace declared here.
}

gaps {
    // All values below are in points. `inner` is the spacing between
    // sibling tiled windows.
    inner 4

    // `outer` is the padding around the whole tiled area. Either one number
    // (same on all 4 sides) or four numbers in CSS order: top, right,
    // bottom, left.
    outer 8 16 16 16

    // How many points of a non-visible accordion sibling peek out from
    // behind the active one. 0 collapses every child to the same full frame.
    accordion 32

    // Per-workspace override — put any workspace name declared above here
    // to override `inner`/`outer`/`accordion` just for it; anything not
    // listed here uses this block's own defaults, not whatever's set above.
    // workspace "random" {
    //     inner 0
    //     outer 0
    // }
}

settings {
    // KDL v2 booleans are `#true`/`#false` (note the `#` — bare `true`/
    // `false` is a parse error, unlike KDL v1 or most other config formats).
    auto-reload #true

    // Which declared workspace is active at daemon startup. Falls back to
    // the alphabetically-first declared workspace if omitted.
    default-workspace "entertain"

    // Warps the cursor to the newly-focused window (M10). On by default.
    mouse-follows-focus #false

    // Moving the cursor onto a different monitor focuses it, same as the
    // `focus-monitor` command (M10). On by default.
    focus-follows-monitor #true

    // Orientation a workspace's root container gets when it's created for
    // its second window: "auto" (derive from the monitor's aspect ratio),
    // "horizontal", or "vertical".
    default-root-orientation "auto"
}

// Global hotkeys — no external tool (skhd etc.) needed, tili captures these
// itself. Key strings are "modifier-modifier-key", e.g. "alt-shift-h";
// modifiers can be listed in any order. Recognized modifiers: alt/option,
// cmd/command, ctrl/control, shift. Base key names: letters, digits,
// punctuation ("slash"/"semicolon"/"minus"/"equal"/...), and
// "escape"/"enter"/"space"/"tab"/arrow keys.
//
// `mode="main"` below is the mode active by default; you can also declare
// your own named modes (see "resize"/"manage" further down) and switch
// into them with the `mode <name>` command. Every command below can be
// bound in any mode, not just "main" — these are just where the defaults
// happen to put them.
//
// Full list of commands usable as a `bind`'s second argument (`<dir>` is
// always one of left/right/up/down):
//   focus <dir>                     move focus to the neighboring window
//   move <dir>                      move the focused window itself
//   join <dir>                      wrap focused window + neighbor in a new
//                                    perpendicular container
//   workspace <name>                switch to a declared workspace
//   workspace-back                  switch back to the previously-active one
//   move-node-to-workspace <name>   move the focused window to a workspace
//   move-workspace-to-monitor next|main
//                                   move the active (or a named) workspace
//                                   to another connected monitor
//   layout toggle[ root]            flip focused container Tiles<->Accordion
//   layout tiles[ root]             set focused container to Tiles
//   layout accordion[ root]         set focused container to Accordion
//   layout horizontal[ root]        set focused container's split axis
//   layout vertical[ root]          set focused container's split axis
//   layout toggle-orientation[ root]
//                                   flip focused container's split axis
//   resize <amount>                 grow/shrink focused window's share,
//                                   e.g. "0.1" or "-0.1" (container
//                                   weight-space, not pixels)
//   balance[ root]                  reset all siblings back to equal shares
//   flatten                         merge a redundant single-child container
//                                   into its parent
//   fullscreen[ native]             toggle fullscreen; "native" uses a real
//                                   macOS Space instead of just filling the
//                                   monitor within tili's own layout
//   close                           close the focused window
//   summon <text>                   focus+switch to the first window whose
//                                   title or bundle id contains <text>
//   set-floating on|off             toggle the focused window between
//                                   tiled and floating at runtime
//   focus-monitor                   cycle which connected monitor commands
//                                   target (no-op with only one monitor)
//   mode <name>                     switch to a named keybindings mode
//   mode exit                       return to the default ("main") mode
//
// A trailing "root" (where shown above) targets the workspace's whole root
// container instead of just the focused window's nearest one.
keybindings mode="main" {
    bind "alt-h" "focus left"
    bind "alt-l" "focus right"
    bind "alt-j" "focus down"
    bind "alt-k" "focus up"

    bind "alt-shift-h" "move left"
    bind "alt-shift-l" "move right"
    bind "alt-shift-j" "move down"
    bind "alt-shift-k" "move up"

    // Wraps the focused window and its neighbor into a new, perpendicular
    // container — e.g. "join left" on a row of windows stacks the focused
    // one with its left neighbor.
    bind "alt-shift-g" "join left"

    bind "alt-w" "workspace work"
    bind "alt-e" "workspace entertain"
    bind "alt-r" "workspace random"

    bind "alt-shift-w" "move-node-to-workspace work"
    bind "alt-shift-e" "move-node-to-workspace entertain"
    bind "alt-shift-r" "move-node-to-workspace random"

    // Switches back to whichever workspace was active before this one.
    bind "alt-tab" "workspace-back"

    // Moves the current workspace to the next connected monitor — a no-op
    // with only one monitor.
    bind "alt-shift-tab" "move-workspace-to-monitor next"

    bind "alt-slash" "layout toggle"

    // Flips the focused container's split axis between horizontal and
    // vertical — pairs with "layout toggle" above (tiles vs. accordion).
    bind "alt-shift-slash" "layout toggle-orientation"

    // Grows/shrinks the focused window's share of its nearest tiled
    // container, or resets that container's children back to equal
    // shares.
    bind "alt-shift-minus" "resize -0.1"
    bind "alt-shift-equal" "resize 0.1"
    bind "alt-shift-0" "balance"

    // Cycles which connected monitor the above all target — a no-op with
    // only one monitor. See ROADMAP.md M9.
    bind "alt-m" "focus-monitor"

    // Enter a submode — its own keybindings block takes over until it
    // exits back to "main".
    bind "alt-shift-semicolon" "mode resize"

    // One-shot mode: fires a single bound command, then returns to "main"
    // automatically (see the "manage" mode below).
    bind "alt-shift-s" "mode manage"
}

keybindings mode="resize" {
    // Grows/shrinks the focused window's share of its nearest tiled
    // container — the amount is in the container's own weight-space, not
    // pixels, so small steps like these are the right scale.
    bind "h" "resize -0.1"
    bind "l" "resize 0.1"

    bind "escape" "mode main"
    bind "enter" "mode main"
}

// `auto-exit` (#true) makes this a one-shot mode: any bound command fires
// and then returns to "main" automatically, with no explicit exit bind
// needed.
keybindings mode="manage" auto-exit=#true {
    bind "escape" "reload-config"
    bind "r" "flatten"
    bind "alt-shift-h" "join left"
    bind "alt-shift-j" "join down"
    bind "alt-shift-k" "join up"
    bind "alt-shift-l" "join right"
}

// Auto-assigns a matching app's windows to a specific declared workspace on
// creation, regardless of whatever workspace is currently active — and
// regardless of whether that app ends up tiled or floating (see
// `floating-rules` below for that separate concern). Matched in order,
// first match wins. If the target workspace isn't visible on any monitor
// right now, the window is parked until you switch to it.
//   app-id     required. The target app's bundle identifier (find one with
//              `osascript -e 'id of app "Finder"'` or `mdls -name
//              kMDItemCFBundleIdentifier /Applications/Finder.app`).
//   workspace  required. Must name a workspace declared above.
workspace-rules {
    rule app-id="com.mitchellh.ghostty" workspace="work"
    rule app-id="com.apple.Safari" workspace="entertain"
}

// Windows matching one of these float instead of tiling, and are sized on
// creation (auto-centered only for rules/apps that opt in via `center
// #true` — `defaults.center` below is off, so an app with no explicit
// `center` just lands at the floating area's top-left). Matched in order —
// first match wins. Each `rule` supports:
//   app-id     required. The target app's bundle identifier (find one with
//              `osascript -e 'id of app "Finder"'` or `mdls -name
//              kMDItemCFBundleIdentifier /Applications/Finder.app`).
//   title      optional. A regex matched against the window title, for
//              narrowing a rule to specific dialogs of an app that should
//              otherwise tile normally.
//   mode       optional, one of "float" (default)/"tile"/"ignore" —
//              overrides tili's own guess at whether the window should
//              float, tile, or be left completely untouched. Useful for an
//              app tili misclassifies, without needing a source change.
//   width      optional, in points. Falls back to `defaults.width-ratio`.
//   height     optional, in points. Falls back to `defaults.height-ratio`.
//   center     optional. Falls back to `defaults.center`.
// `width`/`height`/`center` go in a `{ }` body after the rule, as shown
// below — only meaningful when `mode` is "float" (the default).
floating-rules {
    rule app-id="com.apple.ActivityMonitor"
    rule app-id="com.apple.AddressBook"
    rule app-id="com.apple.AppStore"
    rule app-id="com.apple.calculator"
    rule app-id="com.apple.FaceTime"
    rule app-id="com.apple.finder"
    rule app-id="com.apple.findmy"
    rule app-id="com.apple.iBooksX"
    rule app-id="com.apple.iCal"
    rule app-id="com.apple.mail"
    rule app-id="com.apple.MobileSMS"
    rule app-id="com.apple.Music"
    rule app-id="com.apple.Notes"
    rule app-id="com.apple.Passwords"
    rule app-id="com.apple.Photos"
    rule app-id="com.apple.reminders"
    rule app-id="com.apple.systempreferences"
    rule app-id="com.cloudflare.1dot1dot1dot1.macos"
    rule app-id="ru.keepcoder.Telegram"

    // Example: a rule can override `defaults` per app with its own
    // width/height (in points) and center flag. Left commented out since
    // the plain "com.apple.systempreferences" rule above already matches
    // first and would make this one unreachable.
    // rule app-id="com.apple.systempreferences" { width 900; height 600; center #true }

    // Only Finder's "Copy"/"Connect to Server" style dialogs float — other
    // Finder windows are already covered by the plain rule above, so this
    // one only matters for apps you'd otherwise want tiled.
    rule app-id="com.apple.finder" title="^(Copy|Connect to Server)$"

    // mode="tile" rescues a window back into normal tiling even if tili's
    // AX heuristic classified it as a dialog (some apps mark an ordinary
    // resizable window with a dialog-like subrole) — replace the app-id
    // below with whatever app you've actually observed being misclassified.
    // rule app-id="com.example.misclassified-dialog-app" mode="tile"

    // mode="ignore" leaves a window's position/size alone entirely — no
    // tiling, no floating, no auto-centering. Useful for a small
    // menu-bar-only utility panel that should never be touched.
    // rule app-id="com.example.menu-bar-panel" mode="ignore"

    defaults {
        center #true
        width-ratio 0.6
        height-ratio 0.8
    }
}
